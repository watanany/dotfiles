{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dippy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$NVIM\" ] && nvim --server \"$NVIM\" --remote-expr 'execute(\"lua claude_notify_done()\")' || true"
          },
          {
            "type": "command",
            "command": "PROJ_KEY=$(pwd | sed 's|[/._]|-|g'); MEMORY_CTX=\"$HOME/.claude/projects/$PROJ_KEY/memory/current_context.md\"; if [ -f \"$MEMORY_CTX\" ]; then STAMP=\"/tmp/claude_ctx$PROJ_KEY\"; NOW=$(date +%s); LAST=$(cat \"$STAMP\" 2>/dev/null || echo 0); if [ $((NOW - LAST)) -gt 1800 ]; then echo \"$NOW\" > \"$STAMP\"; echo \"[reminder] current_context.md の更新を忘れずに: $MEMORY_CTX\"; fi; fi; true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "skipAutoPermissionPrompt": true
}
